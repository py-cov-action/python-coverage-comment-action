{
  extends: ["config:recommended", ":enablePreCommit"],
  labels: ["deps"],
  minimumReleaseAge: "5 days",
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
  },
  packageRules: [
    {
      groupName: "all dependencies",
      groupSlug: "all",
      matchPackageNames: ["*"],
    },
  ],
  automerge: true,
}
